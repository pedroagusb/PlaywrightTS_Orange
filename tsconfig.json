{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": ["ES2020"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "./dist",
        "rootDir": "./",
        "resolveJsonModule": true
    },
    "include": [
        "src/**/*",
        "tests/**/*",
        "utils/**/*",
        "data/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}